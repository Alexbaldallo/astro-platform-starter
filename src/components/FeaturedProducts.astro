---
import ProductCard from './ProductCard.astro';
import { WATCHES_DATABASE } from '../data/watchesDatabase.js';

// Esperar a que se carguen los datos
await WATCHES_DATABASE.load();

// Actualizar precios
WATCHES_DATABASE.updatePrices();

// Obtener productos
const products = WATCHES_DATABASE.getProducts('all', 6);

const updated = new Date().toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
---

<section class="featured-products" id="productos">
    <div class="container">
        <header class="section-header">
            <p class="section-kicker">Selección del día</p>
            <h2 class="section-title">Ofertas en Amazon</h2>
            <p class="update-time">Precios revisados el {updated}</p>
        </header>

        <div class="products-grid">
            {products.map((product) => <ProductCard {...product} />)}
        </div>

        <p class="affiliate-note">Los precios pueden variar en Amazon. Al comprar a través de nuestros enlaces, Amazon nos paga una pequeña comisión sin coste extra para ti.</p>
    </div>
</section>

<style>
    .featured-products {
        padding: 5rem 1.5rem;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .section-header {
        text-align: center;
        margin-bottom: 3.5rem;
    }

    .section-kicker {
        font-size: 0.78rem;
        letter-spacing: 0.45em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 1rem;
    }

    .section-title {
        font-size: 2.6rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        color: var(--text-primary);
    }

    .section-title::after {
        content: '';
        display: block;
        width: 64px;
        height: 1px;
        background: var(--gold-gradient);
        margin: 1.25rem auto 0;
    }

    .update-time {
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .products-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    .affiliate-note {
        margin-top: 2.5rem;
        text-align: center;
        color: var(--text-muted);
        font-size: 0.82rem;
        max-width: 640px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.6;
    }

    @media (min-width: 768px) {
        .products-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .products-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
</style>
