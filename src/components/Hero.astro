---
import Header from './Header.astro';
---

<Header />

<section class="hero" id="inicio">
    <div class="hero-ring" aria-hidden="true"></div>
    <div class="hero-content">
        <p class="hero-kicker">Relojería seleccionada</p>
        <h1 class="hero-title">El tiempo, <em>bien elegido</em></h1>
        <p class="hero-subtitle">
            Cada día revisamos Amazon para encontrar relojes de marcas originales con descuentos reales. Tú eliges; del envío y la garantía se
            encarga Amazon.
        </p>
        <div class="hero-actions">
            <a href="#productos" class="cta-button">Ver la colección</a>
            <a href="#ventajas" class="ghost-button">Por qué Chronux</a>
        </div>
        <ul class="hero-trust">
            <li>Marcas originales</li>
            <li>Garantía oficial</li>
            <li>Envío por Amazon</li>
        </ul>
    </div>
</section>

<style>
    .hero {
        min-height: 82vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 4rem 1.5rem;
        position: relative;
        overflow: hidden;
    }

    /* Esfera de reloj decorativa dibujada con CSS */
    .hero-ring {
        position: absolute;
        width: 780px;
        height: 780px;
        border-radius: 50%;
        border: 1px solid rgba(201, 168, 106, 0.18);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        pointer-events: none;
    }

    .hero-ring::before {
        content: '';
        position: absolute;
        inset: 34px;
        border-radius: 50%;
        background: repeating-conic-gradient(rgba(201, 168, 106, 0.35) 0deg 0.6deg, transparent 0.6deg 30deg);
        -webkit-mask: radial-gradient(closest-side, transparent 91%, #000 92%);
        mask: radial-gradient(closest-side, transparent 91%, #000 92%);
    }

    .hero-ring::after {
        content: '';
        position: absolute;
        inset: 90px;
        border-radius: 50%;
        border: 1px solid rgba(201, 168, 106, 0.09);
    }

    .hero-content {
        max-width: 820px;
        margin: 0 auto;
        position: relative;
    }

    .hero-kicker {
        font-size: 0.78rem;
        letter-spacing: 0.45em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 1.5rem;
    }

    .hero-kicker::before,
    .hero-kicker::after {
        content: '——';
        color: var(--line-gold);
        margin: 0 0.9rem;
        letter-spacing: normal;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        line-height: 1.12;
        color: var(--text-primary);
    }

    .hero-title em {
        font-style: italic;
        background: var(--gold-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-subtitle {
        font-size: 1.1rem;
        margin: 0 auto 2.5rem;
        color: var(--text-secondary);
        max-width: 560px;
        line-height: 1.7;
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 3rem;
    }

    .cta-button {
        display: inline-block;
        padding: 1rem 2.5rem;
        background: var(--gold-gradient);
        color: #14110a;
        text-decoration: none;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(201, 168, 106, 0.25);
    }

    .cta-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 40px rgba(201, 168, 106, 0.35);
    }

    .ghost-button {
        display: inline-block;
        padding: 1rem 2.5rem;
        background: transparent;
        color: var(--text-primary);
        text-decoration: none;
        border: 1px solid var(--line-gold);
        border-radius: 4px;
        font-weight: 500;
        font-size: 0.85rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        transition: all 0.3s ease;
    }

    .ghost-button:hover {
        border-color: var(--gold);
        color: var(--gold-strong);
    }

    .hero-trust {
        display: flex;
        gap: 2.5rem;
        justify-content: center;
        flex-wrap: wrap;
        list-style: none;
    }

    .hero-trust li {
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .hero-trust li::before {
        content: '✓';
        color: var(--gold);
        margin-right: 0.5rem;
    }

    @media (min-width: 768px) {
        .hero-title {
            font-size: 4.2rem;
        }
    }

    @media (min-width: 1024px) {
        .hero-title {
            font-size: 5rem;
        }
    }
</style>
