---
// Props de cada producto
export interface Props {
    name: string;
    brand: string;
    currentPrice: number;
    originalPrice: number;
    discount: number;
    features: string[];
    bestseller?: boolean;
    flashSale?: boolean;
    affiliateLink?: string;
    image: string;
}

const { name, brand, currentPrice, originalPrice, discount, features, bestseller = false, flashSale, affiliateLink = '#', image } = Astro.props;

const euros = new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' });
---

<article class="product-card">
    <a href={affiliateLink} target="_blank" rel="sponsored nofollow noopener" class="product-image" aria-label={`Ver ${name} en Amazon`}>
        {bestseller && <span class="badge badge-bestseller">Más vendido</span>}
        {flashSale && <span class="badge badge-flash">Oferta flash</span>}
        <img src={image} alt={name} class="watch-img" loading="lazy" />
    </a>

    <div class="product-info">
        <p class="product-brand">{brand}</p>
        <h3 class="product-name">{name}</h3>

        <div class="product-price">
            <span class="price-current">{euros.format(currentPrice)}</span>
            {
                discount > 0 && (
                    <>
                        <span class="price-original">{euros.format(originalPrice)}</span>
                        <span class="discount">−{discount}%</span>
                    </>
                )
            }
        </div>

        <ul class="product-features">
            {features.map((feature) => <li>{feature}</li>)}
        </ul>

        <a href={affiliateLink} target="_blank" rel="sponsored nofollow noopener" class="buy-button">
            Ver oferta en Amazon
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                <path d="M7 17L17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </a>
    </div>
</article>

<style>
    .product-card {
        display: flex;
        flex-direction: column;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 10px;
        overflow: hidden;
        transition:
            transform 0.35s ease,
            box-shadow 0.35s ease,
            border-color 0.35s ease;
    }

    .product-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 24px 50px rgba(0, 0, 0, 0.45);
        border-color: var(--line-gold);
    }

    /* Panel claro tipo tienda: las fotos de Amazon (fondo blanco) se integran */
    .product-image {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        height: 270px;
        padding: 1.75rem;
        background: linear-gradient(180deg, #faf9f6 0%, #edeae3 100%);
    }

    .watch-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        transition: transform 0.4s ease;
    }

    .product-card:hover .watch-img {
        transform: scale(1.05);
    }

    .badge {
        position: absolute;
        top: 1rem;
        padding: 0.35rem 0.8rem;
        border-radius: 3px;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        z-index: 2;
    }

    .badge-bestseller {
        left: 1rem;
        background: #14110a;
        color: var(--gold-strong);
    }

    .badge-flash {
        right: 1rem;
        background: #b3261e;
        color: #fff;
    }

    .product-info {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: 1.5rem;
    }

    .product-brand {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 0.35rem;
    }

    .product-name {
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--text-primary);
    }

    .product-price {
        display: flex;
        align-items: baseline;
        gap: 0.6rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

    .price-current {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
    }

    .price-original {
        text-decoration: line-through;
        color: var(--text-muted);
        font-size: 1rem;
    }

    .discount {
        background: var(--gold-gradient);
        color: #14110a;
        padding: 0.2rem 0.55rem;
        border-radius: 3px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .product-features {
        list-style: none;
        margin-bottom: 1.5rem;
        border-top: 1px solid var(--line);
        padding-top: 1rem;
    }

    .product-features li {
        padding: 0.28rem 0;
        color: var(--text-secondary);
        font-size: 0.88rem;
    }

    .product-features li::before {
        content: '✓';
        color: var(--gold);
        font-weight: bold;
        margin-right: 0.6rem;
    }

    .buy-button {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin-top: auto;
        width: 100%;
        padding: 0.95rem;
        background: var(--gold-gradient);
        color: #14110a;
        border: none;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.82rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        box-shadow: 0 5px 15px rgba(201, 168, 106, 0.2);
    }

    .buy-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(201, 168, 106, 0.35);
    }
</style>
