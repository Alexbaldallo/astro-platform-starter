---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturedProducts from '../components/FeaturedProducts.astro';
import Features from '../components/Features.astro';
import Footer from '../components/Footer.astro';

// Renderizado en el servidor: cada visita lee la hoja de Google actualizada.
// El CDN de Netlify cachea la página 5 minutos para no llamar a Google en cada visita.
export const prerender = false;

Astro.response.headers.set('Cache-Control', 'public, max-age=0, must-revalidate');
Astro.response.headers.set('Netlify-CDN-Cache-Control', 'public, durable, s-maxage=300, stale-while-revalidate=86400');

const title = 'Chronux — Relojes premium al mejor precio';
const description = 'Selección diaria de relojes de marcas originales con descuentos reales en Amazon. Elegancia, precisión y estilo en tu muñeca.';
---

<Layout title={title} description={description}>
    <Hero />
    <FeaturedProducts />
    <Features />
    <Footer />
</Layout>

<script>
    import '../scripts/main.js';
</script>
