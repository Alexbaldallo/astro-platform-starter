---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturedProducts from '../components/FeaturedProducts.astro';
import Features from '../components/Features.astro';
import Footer from '../components/Footer.astro';

const title = 'Chronux — Relojes premium al mejor precio';
const description = 'Selección diaria de relojes de marcas originales con descuentos reales en Amazon. Elegancia, precisión y estilo en tu muñeca.';
---

<Layout title={title} description={description}>
    <Hero />
    <FeaturedProducts />
    <Features />
    <Footer />
</Layout>

<script>
    import '../scripts/main.js';
</script>
