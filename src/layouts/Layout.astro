---
import '@fontsource-variable/inter';
import '@fontsource-variable/playfair-display';

export interface Props {
    title: string;
    description?: string;
}

const { title, description = 'Chronux - Relojes Premium' } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>

        <!-- Meta tags para SEO -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://chronux.shop" />
        <meta property="og:image" content="/og-image.jpg" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content="/og-image.jpg" />
    </head>
    <body>
        <slot />
    </body>
</html>

<style is:global>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        /* Paleta "relojería de lujo": negro cálido + dorado champán */
        --bg: #0b0b0e;
        --bg-soft: #101014;
        --surface: #14141a;
        --line: rgba(255, 255, 255, 0.08);
        --line-gold: rgba(201, 168, 106, 0.35);

        --gold: #c9a86a;
        --gold-strong: #dfc08a;
        --gold-gradient: linear-gradient(135deg, #dfc08a 0%, #c9a86a 45%, #a8843f 100%);

        --text-primary: #f4f1e8;
        --text-secondary: rgba(244, 241, 232, 0.72);
        --text-muted: rgba(244, 241, 232, 0.45);

        /* Alias usados por componentes existentes */
        --glass-bg: rgba(255, 255, 255, 0.04);
        --glass-border: var(--line);
        --accent-gold: var(--gold);
        --primary-gradient: var(--gold-gradient);
        --secondary-gradient: var(--gold-gradient);

        --font-display: 'Playfair Display Variable', Georgia, 'Times New Roman', serif;
        --font-body: 'Inter Variable', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: var(--font-body);
        background-color: var(--bg);
        background-image: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(201, 168, 106, 0.08), transparent 70%);
        color: var(--text-primary);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
    }

    h1,
    h2,
    h3,
    .font-display {
        font-family: var(--font-display);
    }

    ::selection {
        background: var(--gold);
        color: #14110a;
    }
</style>
